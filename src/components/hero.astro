---
import GradientArc from '@/components/gradient-arc.astro';
import SolarSystem from '@/components/react/solar-system';
import Telemetry from '@/components/react/telemetry';
import ScrollHint from '@/components/scroll-hint.astro';
import SocialLink from '@/components/social-link.astro';
---
<section class="hero" id="top">
  <div class="al-hero-solar system-wrap">
    <SolarSystem client:load />
  </div>

  <div class="al-hero-compose compose">
    <div class="al-hero-eyebrow telemetry">
      <Telemetry client:idle />
    </div>

    <p class="al-hero-welcome welcome">
      Hi, I&rsquo;m <em class="welcome-em">Andrea</em>.
    </p>

    <GradientArc />

    <div class="al-hero-role role">
      Senior Software Engineer
      <span class="role-sep"> / </span>
      <span class="role-sub">twenty years of art merging into code.</span>
    </div>

    <div class="al-hero-links links">
      <SocialLink label="github"    href="https://github.com/karedas" />
      <span class="sep" aria-hidden="true">&#9670;</span>
      <SocialLink label="linkedin"  href="https://www.linkedin.com/in/andrea-lisi84" />
      <span class="sep" aria-hidden="true">&#9670;</span>
      <SocialLink label="instagram" href="https://www.instagram.com/alandr.1984/" />
      <span class="sep" aria-hidden="true">&#9670;</span>
      <SocialLink label="email"     href="mailto:lisandr84@gmail.com" />
    </div>
  </div>

  <ScrollHint />
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    background: radial-gradient(ellipse at 50% 35%, #11142a 0%, var(--bg) 70%, var(--bg) 100%);
    padding-top: calc(24px + var(--topbar-h, 88px));
    padding-bottom: 24px;
    overflow: hidden;
  }
  .system-wrap {
    position: relative;
    width: 100%;
    height: min(620px, 60vh);
    margin-top: 30px;
  }
  .compose {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 24px;
    margin-top: 20px;
  }
  .telemetry {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.5em;
    color: var(--fg-dim);
    margin-bottom: 28px;
    text-transform: uppercase;
  }
  .welcome {
    margin: 0 0 18px;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(32px, 4vw, 52px);
    color: var(--fg);
    letter-spacing: -0.005em;
    line-height: 1.15;
  }
  .welcome-em {
    font-style: italic;
    font-weight: 500;
    background: linear-gradient(95deg, var(--amber) 0%, var(--gold-hi) 30%, var(--sage) 60%, var(--cyan) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }
  .role {
    margin-top: 28px;
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 500;
    color: var(--fg);
    letter-spacing: 0.04em;
  }
  .role-sep { color: var(--fg-dim); margin: 0 4px; }
  .role-sub { color: var(--fg-muted); font-style: italic; font-weight: 400; }
  .links {
    margin-top: 38px;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }
  .sep {
    color: var(--fg-dim);
    margin: 0 18px;
    font-size: 11px;
  }
</style>
