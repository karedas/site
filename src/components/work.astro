---
import SectionHeader from '@/components/section-header.astro';

// Bold spans mirror the emphasis used in the CV PDF (rendered via set:html).
const jobs = [
  {
    years: '2023 · NOW',
    place: 'VIENNA, AT',
    company: 'Tricentis · Tosca Cloud',
    role: 'Frontend Platform & Governance · Staff scope',
    tags: ['Nx Monorepo', 'Micro-frontends', 'RFC culture', 'Agentic AI'],
    current: true,
    desc: 'Own the <b>frontend platform architecture</b>: Nx monorepo, module boundaries and CI topology across 16 projects. Co-lead <b>governance for 12+ dev teams</b> and drive the <b>maintenance, modernization and scalability of the entire product</b>: micro-frontend architecture, repo and build tooling, engineering standards, observability. Re-engineered the <b>CI/CD pipelines, migrating from Azure DevOps to GitHub</b>, with build and test times cut by more than half, and <b>AI integrated at every level</b> of delivery.',
  },
  {
    years: '2019 · 2023',
    place: 'FLORENCE, IT',
    company: 'Treedom',
    role: 'Frontend Developer',
    tags: ['React', 'Vue', 'GraphQL'],
    current: false,
    desc: 'Joined to reinforce the storefront, then helped drive the <b>full migration away from the monolith</b> in a core team of four, owning the frontend track with React, Vue and GraphQL. The <b>foundations we laid supported growth to 25 developers</b>, building <b>high-traffic campaign pages</b> for a platform that planted millions of trees.',
  },
  {
    years: '2017 · 2019',
    place: 'FLORENCE, IT',
    company: 'Forzieri.com',
    role: 'Frontend Developer',
    tags: ['React', 'Webpack', 'jQuery → React'],
    current: false,
    desc: 'Modernized a <b>legacy ASP e-commerce end to end</b>: an incremental migration first to jQuery, then to <b>React with a Webpack toolchain</b>, spanning frontend, backend and database integration, while the <b>live luxury shop kept shipping features</b>.',
  },
  {
    years: '2007 · 2017',
    place: 'FIGLINE VALDARNO, IT',
    company: 'Easysystem',
    role: 'Head of Web · Full-Stack Designer',
    tags: ['Design', 'Full-stack', 'Infrastructure'],
    current: false,
    desc: "Hired as the studio's designer, <b>prototypes and visual identities drawn from scratch</b>, then grown into the <b>on-premise infrastructure technician</b>: servers, networking and firewalls inside client companies, notably Tuscany's leather and fashion district. A decade of <b>end-to-end ownership across dozens of clients</b>, design to Windows Server operations.",
  },
];
---
<section id="work" data-sec="3" class="section">
  <SectionHeader num="03" title="Selected work" eyebrow="THE ONES THAT MATTERED" />

  <div class="jobs">
    {jobs.map((job) => (
      <article class:list={['job', { current: job.current }]} data-rv>
        <span class="node" aria-hidden="true"></span>
        <div class="when">
          <div class="years">{job.years}</div>
          <div class="place">{job.place}</div>
          {job.current && (
            <div class="badge"><span class="dot" aria-hidden="true"></span>CURRENT</div>
          )}
        </div>
        <div class="what">
          <h3 class="company">{job.company}</h3>
          <div class="role">{job.role}</div>
          <p class="desc" set:html={job.desc} />
        </div>
        <div class="tags">
          {job.tags.map((tag) => <span class="mono-tag">{tag}</span>)}
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .jobs {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--line-12);
  }

  .job {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    gap: 20px 32px;
    padding: 34px 24px 34px 58px;
    border-bottom: 1px solid var(--line-12);
    transition: background 0.2s;
  }

  .job:hover {
    background: rgba(237, 229, 220, 0.03);
  }

  /* Timeline spine: commit-style nodes, echoing the CV's git-graph. */
  .node {
    position: absolute;
    left: 24px;
    top: 39px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    border: 1.5px solid var(--accent-rust);
    background: var(--bg);
  }

  .job::after {
    content: "";
    position: absolute;
    left: 29px;
    top: 56px;
    bottom: -40px;
    width: 1px;
    background: var(--line-12);
    pointer-events: none;
  }

  .job:last-child::after {
    display: none;
  }

  .job.current {
    background: rgba(232, 112, 58, 0.04);
  }

  .job.current:hover {
    background: rgba(232, 112, 58, 0.07);
  }

  .job.current .node {
    border-color: var(--accent);
    background: var(--accent);
    box-shadow: 0 0 12px rgba(232, 112, 58, 0.6);
    animation: pulseDot 2s infinite;
  }

  .when {
    flex: 0 0 150px;
  }

  .years {
    font: 500 13px var(--font-mono);
    color: var(--accent);
  }

  .place {
    margin-top: 8px;
    font: 400 11px var(--font-mono);
    letter-spacing: 0.1em;
    color: var(--fg-56);
  }

  .badge {
    display: inline-block;
    margin-top: 12px;
    font: 400 10px var(--font-mono);
    letter-spacing: 0.16em;
    color: var(--accent);
    border: 1px solid var(--accent-line);
    padding: 5px 10px;
  }

  .badge .dot {
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    margin-right: 7px;
    animation: pulseDot 2s infinite;
  }

  .what {
    flex: 1 1 320px;
    min-width: 260px;
  }

  .company {
    margin: 0;
    font: 600 24px var(--font-display);
    color: var(--accent);
  }

  .role {
    margin-top: 4px;
    font: 400 14px var(--font-display);
    color: rgba(237, 229, 220, 0.6);
  }

  .desc {
    margin: 14px 0 0;
    font: 300 15px/1.7 var(--font-display);
    color: var(--fg-70);
    max-width: 620px;
    text-wrap: pretty;
  }

  .desc :global(b) {
    font-weight: 500;
    color: var(--fg);
  }

  .tags {
    flex: 1 1 200px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-content: start;
    justify-content: flex-end;
  }
</style>
