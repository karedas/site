---
interface Item {
  num: string;
  label: string;
  target: string;
}

const items: Item[] = [
  { num: '00', label: 'Home', target: 'top' },
  { num: '01', label: 'About', target: 'about' },
  { num: '02', label: 'Skills', target: 'skills' },
  { num: '03', label: 'Work', target: 'work' },
  { num: '04', label: 'Projects', target: 'projects' },
  { num: '05', label: 'Off-orbit', target: 'off-orbit' },
];
---
<nav class="al-menu menu" aria-label="Sections" data-menu>
  <ol class="menu-list" data-menu-list>
    {items.map((it) => (
      <li class="menu-item">
        <a
          class="menu-link"
          href={`#${it.target}`}
          data-menu-link
          data-target={it.target}
        >
          <span class="menu-num" aria-hidden="true">{it.num}</span>
          <span class="menu-label">{it.label}</span>
        </a>
      </li>
    ))}
    <span class="menu-rocket" data-menu-rocket aria-hidden="true">
      <span class="menu-rocket-inner" data-menu-rocket-inner>
        <svg
          class="menu-rocket-svg"
          viewBox="0 0 16 24"
          width="16"
          height="24"
          xmlns="http://www.w3.org/2000/svg"
          focusable="false"
          role="presentation"
        >
          <path
            d="M8 1.5 L11.5 7 H4.5 Z"
            stroke="var(--gold-hi)"
            stroke-width="1"
            fill="none"
            stroke-linejoin="round"
          />
          <rect
            x="4.5"
            y="7"
            width="7"
            height="11"
            rx="1.5"
            stroke="var(--gold)"
            stroke-width="1"
            fill="rgba(232, 161, 58, 0.06)"
          />
          <circle cx="8" cy="11.5" r="1.4" fill="var(--cyan)" />
          <path
            d="M4.5 18 L1.5 22 L4.5 22 Z"
            stroke="var(--gold)"
            stroke-width="1"
            fill="none"
            stroke-linejoin="round"
          />
          <path
            d="M11.5 18 L14.5 22 L11.5 22 Z"
            stroke="var(--gold)"
            stroke-width="1"
            fill="none"
            stroke-linejoin="round"
          />
        </svg>
        <span class="menu-flame" aria-hidden="true"></span>
      </span>
    </span>
  </ol>
</nav>

<style>
  .menu {
    display: flex;
    align-items: stretch;
    justify-content: center;
    width: 100%;
    pointer-events: auto;
  }
  .menu-list {
    list-style: none;
    margin: 0;
    padding: 4px 0 4px;
    position: relative;
    isolation: isolate;
    display: flex;
    align-items: stretch;
    justify-content: center;
    flex-wrap: nowrap;
    gap: 0;
  }
  /* Thin horizontal rail. The rocket rides on it (rocket is on top, the
     rail passes behind it). Centered on the link-dot center: dots use
     `top: 0` + translateY(-50%) inside .menu-link, so their center sits
     at .menu-list's padding-top (4px). */
  .menu-list::before {
    content: "";
    position: absolute;
    left: 5%;
    right: 5%;
    top: 4px;
    height: 1px;
    transform: translateY(-50%);
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--gold-dim) 8%,
      var(--amber) 30%,
      var(--sage) 55%,
      var(--cyan) 80%,
      transparent 100%
    );
    opacity: 0.5;
    pointer-events: none;
  }

  .menu-item {
    margin: 0;
    padding: 0;
    position: relative;
    z-index: 0;
  }
  .menu-link {
    position: relative;
    z-index: 0;
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    padding: 14px 14px 0;
    text-decoration: none;
    color: var(--fg-muted);
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    transition: color 200ms ease;
    outline-offset: 4px;
    border-radius: 2px;
  }
  /* Small dot tying each link to the rail above it. */
  .menu-link::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 0;
    z-index: 0;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--bg);
    border: 1px solid var(--gold-dim);
    transform: translate(-50%, -50%);
    transition:
      background 200ms ease,
      border-color 200ms ease,
      box-shadow 200ms ease,
      opacity 160ms ease;
    pointer-events: none;
  }
  .menu-num {
    color: var(--fg-dim);
    font-variant-numeric: tabular-nums;
    font-size: 10px;
    letter-spacing: 0.18em;
    transition: color 200ms ease;
  }
  .menu-label {
    color: inherit;
  }
  .menu-link:hover,
  .menu-link:focus-visible {
    color: var(--fg);
  }
  .menu-link:hover .menu-num,
  .menu-link:focus-visible .menu-num {
    color: var(--gold);
  }
  .menu-link:hover::before,
  .menu-link:focus-visible::before {
    border-color: var(--gold);
  }
  .menu-link.is-active {
    color: var(--amber);
  }
  .menu-link.is-active .menu-num {
    color: var(--amber);
  }
  .menu-link.is-active::before {
    background: var(--amber);
    border-color: var(--amber);
    box-shadow: 0 0 8px rgba(232, 161, 58, 0.5);
  }
  /* Hide the active dot once the rocket has caught up (avoids double mark). */
  .menu.rocket-settled .menu-link.is-active::before {
    opacity: 0;
    box-shadow: none;
  }

  .menu-rocket {
    position: absolute;
    top: -8px;
    left: 0;
    transform: translateX(var(--rocket-x, 0px)) translateX(-50%);
    pointer-events: none;
    will-change: transform;
    z-index: 10;
  }
  /* Inner wrapper holds the rotation so X translation stays JS-driven.
     The rotation animates briefly (visible but quick) so the user sees
     the rocket physically turn around. */
  .menu-rocket-inner {
    display: inline-block;
    position: relative;
    transform: rotate(var(--rocket-rot, 90deg));
    transform-origin: 50% 50%;
    transition: transform 360ms cubic-bezier(0.33, 0.86, 0.2, 1);
    will-change: transform;
  }
  .menu-rocket-svg {
    display: block;
    filter: drop-shadow(0 0 4px rgba(232, 161, 58, 0.35));
  }
  /* Flame: hot white core fading through gold → amber → ember red, with
     an outer halo so it reads against the dark background. */
  .menu-flame {
    position: absolute;
    left: 50%;
    top: 100%;
    width: 8px;
    height: 16px;
    border-radius: 50% 50% 50% 50% / 35% 35% 75% 75%;
    transition:
      opacity 420ms ease,
      transform 420ms ease,
      filter 420ms ease;
    background:
      radial-gradient(
        ellipse 4px 7px at 50% 22%,
        #fff5d8 0%,
        rgba(255, 222, 150, 0.85) 35%,
        transparent 70%
      ),
      linear-gradient(
        180deg,
        var(--gold-hi) 0%,
        var(--amber) 38%,
        #c54a1a 78%,
        rgba(197, 74, 26, 0) 100%
      );
    transform: translate(-50%, -2px);
    transform-origin: top center;
    animation: al-menu-flame 0.9s ease-in-out infinite;
    opacity: 1;
    filter: drop-shadow(0 0 5px rgba(255, 170, 70, 0.7));
    pointer-events: none;
  }
  .menu.rocket-engine-off .menu-flame {
    animation: none;
    opacity: 0;
    transform: translate(-50%, 2px) scale(0.25, 0.15);
    filter: none;
  }
  .menu.rocket-engine-off .menu-rocket-svg {
    filter: drop-shadow(0 0 2px rgba(232, 161, 58, 0.15));
  }
  @keyframes al-menu-flame {
    0%,
    100% {
      transform: translate(-50%, -2px) scale(1, 1);
      opacity: 1;
    }
    50% {
      transform: translate(-50%, -2px) scale(0.85, 0.7);
      opacity: 0.85;
    }
  }

  @media (max-width: 1024px) {
    .menu-link {
      padding: 12px 10px 0;
      gap: 6px;
      letter-spacing: 0.18em;
    }
  }
  @media (max-width: 768px) {
    .menu-list {
      padding: 4px 0 4px;
      gap: 0;
    }
    .menu-link {
      padding: 12px 6px 0;
      gap: 4px;
      font-size: 10px;
      letter-spacing: 0.14em;
    }
    .menu-num {
      font-size: 9px;
      letter-spacing: 0.14em;
    }
    .menu-rocket {
      top: -6.5px;
    }
    .menu-rocket-svg {
      width: 14px;
      height: 21px;
    }
  }
  @media (max-width: 560px) {
    .menu-label {
      display: none;
    }
    .menu-link {
      padding: 12px 8px 0;
    }
    .menu-num {
      font-size: 11px;
      letter-spacing: 0.18em;
    }
  }

    @media (prefers-reduced-motion: reduce) {
    .menu-flame {
      animation: none;
      opacity: 0.7;
    }
    .menu-rocket-inner {
      transition: none;
    }
    .menu.rocket-engine-off .menu-flame {
      opacity: 0;
    }
  }
</style>

<script>
  /**
   * Section menu: rocket on a horizontal track.
   * — Wheel / trackpad scroll: rocket eases toward the active section dot.
   * — In-page link click (long jumps): rocket moves linearly from start to
   *   destination dot vs scroll progress, avoiding intermediate “stops”.
   */
  interface Anchor {
    link: HTMLAnchorElement;
    target: string;
    scrollY: number;
    dotX: number;
  }

  function init(): void {
    const menu = document.querySelector<HTMLElement>('[data-menu]');
    if (!menu) return;

    const list = menu.querySelector<HTMLElement>('[data-menu-list]');
    const rocket = menu.querySelector<HTMLElement>('[data-menu-rocket]');
    const inner = menu.querySelector<HTMLElement>('[data-menu-rocket-inner]');
    const links = Array.from(menu.querySelectorAll<HTMLAnchorElement>('[data-menu-link]'));
    if (!list || !rocket || !inner || links.length === 0) return;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const anchors: Anchor[] = [];
    let activeTarget = '';
    let targetX = 0;
    let currentX = 0;
    let rafId = 0;
    let dirty = true;
    type NavMode = 'scroll' | 'anchor';
    let navMode: NavMode = 'scroll';
    let anchorFromY = 0;
    let anchorToY = 0;
    let anchorFromX = 0;
    let anchorToX = 0;
    let anchorGoalTarget = '';
    let anchorFallbackId = 0;
    /** +1 = pointing right, -1 = pointing left. */
    let direction: 1 | -1 = 1;
    /** Accumulated rotation in degrees; default 90° (nose right). */
    let rotation = 90;
    inner.style.setProperty('--rocket-rot', `${rotation}deg`);

    const recomputeAnchors = (): void => {
      anchors.length = 0;
      const listRect = list.getBoundingClientRect();
      const activationOffset = window.innerHeight * 0.35;
      const scrollMax = Math.max(
        0,
        document.documentElement.scrollHeight - window.innerHeight,
      );
      for (const link of links) {
        const target = link.dataset.target;
        if (!target) continue;
        let scrollY = 0;
        if (target !== 'top') {
          const sectionEl = document.getElementById(target);
          if (!sectionEl) continue;
          const sectionRect = sectionEl.getBoundingClientRect();
          scrollY = sectionRect.top + window.scrollY - activationOffset;
        }
        const linkRect = link.getBoundingClientRect();
        const dotX = linkRect.left - listRect.left + linkRect.width / 2;
        anchors.push({ link, target, scrollY, dotX });
      }
      anchors.sort((a, b) => a.scrollY - b.scrollY);
      const tail = anchors[anchors.length - 1];
      const prev = anchors[anchors.length - 2];
      if (tail) {
        /* Last section's activation Y can exceed max scroll; then sy never
           reaches it and the final link never becomes active. */
        const capped = Math.min(tail.scrollY, scrollMax);
        tail.scrollY = prev ? Math.max(capped, prev.scrollY) : capped;
      }
    };

    const dotXForTarget = (target: string): number => {
      if (anchors.length === 0) return 0;
      const hit = anchors.find((a) => a.target === target);
      return hit?.dotX ?? anchors[0]!.dotX;
    };

    /** Dot center from live layout (after is-active toggles, labels reflow). */
    const readActiveDotX = (target: string): number => {
      const listRect = list.getBoundingClientRect();
      const link = links.find((l) => l.dataset.target === target);
      if (!link) return dotXForTarget(target);
      const r = link.getBoundingClientRect();
      return r.left - listRect.left + r.width / 2;
    };

    /** Same threshold for final snap and for hiding the dot under the rocket. */
    const snapEps = 0.04;

    const markSettled = (): void => {
      menu.classList.toggle('rocket-settled', Math.abs(targetX - currentX) < snapEps);
    };

    const scrollMaxY = (): number =>
      Math.max(0, document.documentElement.scrollHeight - window.innerHeight);

    /** Document scrollY the browser will aim for when jumping to `el`. */
    const computeScrollTargetY = (el: HTMLElement): number => {
      const sm = parseFloat(getComputedStyle(el).scrollMarginTop || '0');
      const rootVar = parseFloat(
        getComputedStyle(document.documentElement).getPropertyValue('--topbar-h') || '0',
      );
      const margin =
        !Number.isNaN(sm) && sm > 0 ? sm : !Number.isNaN(rootVar) && rootVar > 0 ? rootVar : 88;
      const y = window.scrollY + el.getBoundingClientRect().top - margin;
      return Math.min(Math.max(0, y), scrollMaxY());
    };

    const exitAnchorNav = (): void => {
      navMode = 'scroll';
      anchorGoalTarget = '';
      window.clearTimeout(anchorFallbackId);
      anchorFallbackId = 0;
      recomputeAnchors();
      const active = findActiveTarget();
      setActive(active);
      targetX = readActiveDotX(active);
      currentX = targetX;
      rocket.style.setProperty('--rocket-x', `${currentX}px`);
      markSettled();
      rafId = 0;
      dirty = false;
    };

    const beginAnchorNav = (target: string): void => {
      const sectionEl =
        target === 'top'
          ? (document.getElementById('top') ?? document.querySelector<HTMLElement>('.hero'))
          : document.getElementById(target);
      if (!sectionEl) return;

      anchorGoalTarget = target;
      anchorFromY = window.scrollY;
      anchorFromX = currentX;
      anchorToY = computeScrollTargetY(sectionEl);
      anchorToX = readActiveDotX(target);

      const denom = anchorToY - anchorFromY;
      if (Math.abs(denom) < 1 && Math.abs(anchorToX - anchorFromX) < snapEps) return;

      navMode = 'anchor';
      window.clearTimeout(anchorFallbackId);
      anchorFallbackId = window.setTimeout(() => {
        if (navMode === 'anchor') exitAnchorNav();
      }, 900);

      if (rafId) cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(tick);
    };

    const findActiveTarget = (): string => {
      if (anchors.length === 0) return '';
      const sy = window.scrollY;
      let active = anchors[0];
      for (const a of anchors) {
        if (sy >= a.scrollY - 1) active = a;
        else break;
      }
      return active?.target ?? '';
    };

    const setActive = (target: string): void => {
      if (target === activeTarget) return;
      activeTarget = target;
      for (const l of links) {
        const isActive = l.dataset.target === target;
        l.classList.toggle('is-active', isActive);
        if (isActive) l.setAttribute('aria-current', 'location');
        else l.removeAttribute('aria-current');
      }
      menu.classList.toggle('rocket-engine-off', target === 'off-orbit');
    };

    /**
     * Single-axis state: rocket points east unless scroll has crossed the
     * midpoint between Projects and Off-orbit (then it points west). Uses
     * a small hysteresis around the threshold so trackpad inertia / browser
     * smooth-scroll overshoot cannot bounce the orientation.
     */
    const computeDesiredDirection = (): 1 | -1 => {
      const proj = anchors.find((a) => a.target === 'projects');
      const off = anchors.find((a) => a.target === 'off-orbit');
      if (!proj || !off || off.scrollY <= proj.scrollY + 8) return direction;

      const sy = window.scrollY;
      const mid = (proj.scrollY + off.scrollY) / 2;
      const eps = Math.max(12, (off.scrollY - proj.scrollY) * 0.02);
      if (sy >= mid + eps) return -1;
      if (sy <= mid - eps) return 1;
      return direction;
    };

    const applyDirection = (desired: 1 | -1): void => {
      if (desired === direction) return;
      direction = desired;
      rotation += desired === 1 ? 180 : -180;
      inner.style.setProperty('--rocket-rot', `${rotation}deg`);
    };

    const tick = (): void => {
      if (navMode === 'anchor') {
        const denom = anchorToY - anchorFromY;
        const t =
          Math.abs(denom) < 0.5
            ? 1
            : Math.min(1, Math.max(0, (window.scrollY - anchorFromY) / denom));
        targetX = anchorFromX + (anchorToX - anchorFromX) * t;
        currentX = targetX;
        rocket.style.setProperty('--rocket-x', `${currentX}px`);
        setActive(findActiveTarget());
        applyDirection(computeDesiredDirection());
        markSettled();

        const sy = window.scrollY;
        const done =
          t >= 0.998 ||
          (denom >= 0 && sy >= anchorToY - 1.5) ||
          (denom < 0 && sy <= anchorToY + 1.5) ||
          Math.abs(sy - anchorToY) < 2.5;

        if (done) {
          exitAnchorNav();
          return;
        }
        rafId = requestAnimationFrame(tick);
        return;
      }

      if (dirty) {
        const active = findActiveTarget();
        setActive(active);
        targetX = readActiveDotX(active);
        applyDirection(computeDesiredDirection());
        dirty = false;
      }
      const dx = targetX - currentX;
      const k = 0.28;
      if (reduced) {
        currentX = targetX;
        rocket.style.setProperty('--rocket-x', `${currentX}px`);
        markSettled();
        rafId = 0;
        return;
      }
      if (Math.abs(dx) < snapEps) {
        currentX = targetX;
        rocket.style.setProperty('--rocket-x', `${currentX}px`);
        markSettled();
        rafId = 0;
        return;
      }
      currentX += dx * k;
      rocket.style.setProperty('--rocket-x', `${currentX}px`);
      markSettled();
      rafId = requestAnimationFrame(tick);
    };

    const schedule = (): void => {
      if (navMode === 'anchor') return;
      dirty = true;
      if (!rafId) rafId = requestAnimationFrame(tick);
    };

    const onResize = (): void => {
      recomputeAnchors();
      if (navMode === 'anchor' && anchorGoalTarget) {
        const goal = anchorGoalTarget;
        const sectionEl =
          goal === 'top'
            ? (document.getElementById('top') ?? document.querySelector<HTMLElement>('.hero'))
            : document.getElementById(goal);
        if (sectionEl) anchorToY = computeScrollTargetY(sectionEl);
        anchorToX = readActiveDotX(goal);
      } else {
        schedule();
      }
    };

    menu.addEventListener(
      'click',
      (e: MouseEvent) => {
        const a = (e.target as HTMLElement).closest('[data-menu-link]') as HTMLAnchorElement | null;
        if (!a) return;
        if (e.defaultPrevented) return;
        if (e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
        const target = a.dataset.target;
        if (!target) return;
        beginAnchorNav(target);
      },
      true,
    );

    window.addEventListener('scroll', schedule, { passive: true });
    window.addEventListener('resize', onResize, { passive: true });
    window.addEventListener('hashchange', schedule, { passive: true });

    recomputeAnchors();
    {
      const proj = anchors.find((a) => a.target === 'projects');
      const off = anchors.find((a) => a.target === 'off-orbit');
      if (proj && off && off.scrollY > proj.scrollY + 8) {
        const mid = (proj.scrollY + off.scrollY) / 2;
        direction = window.scrollY >= mid ? -1 : 1;
        rotation = direction === 1 ? 90 : 270;
        inner.style.setProperty('--rocket-rot', `${rotation}deg`);
      }
    }
    const initial = findActiveTarget();
    setActive(initial);
    targetX = readActiveDotX(initial);
    currentX = targetX;
    rocket.style.setProperty('--rocket-x', `${currentX}px`);
    markSettled();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }
</script>
