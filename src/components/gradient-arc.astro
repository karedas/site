---
---
<svg
  viewBox="0 0 600 60"
  width="100%"
  height="56"
  class="arc"
  aria-hidden="true"
  role="presentation"
>
  <defs>
    <linearGradient id="arc-grad" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%"   stop-color="var(--amber)"   stop-opacity="0" />
      <stop offset="14%"  stop-color="var(--amber)"   stop-opacity="1" />
      <stop offset="38%"  stop-color="var(--gold-hi)" stop-opacity="1" />
      <stop offset="58%"  stop-color="var(--sage)"    stop-opacity="1" />
      <stop offset="82%"  stop-color="var(--cyan)"    stop-opacity="1" />
      <stop offset="100%" stop-color="var(--cyan)"    stop-opacity="0" />
    </linearGradient>
    <filter id="arc-soft" x="-10%" y="-50%" width="120%" height="200%">
      <feGaussianBlur stdDeviation="6" />
    </filter>
  </defs>

  <path
    d="M 20 32 C 160 4, 280 56, 360 26 S 540 8, 580 30"
    stroke="url(#arc-grad)"
    stroke-width="6"
    fill="none"
    filter="url(#arc-soft)"
    opacity="0.55"
  />
  <path
    d="M 20 32 C 160 4, 280 56, 360 26 S 540 8, 580 30"
    stroke="url(#arc-grad)"
    stroke-width="1.3"
    fill="none"
  />

  <circle cx="20"  cy="32" r="2" fill="var(--amber)" opacity="0.6" />
  <circle cx="580" cy="30" r="2" fill="var(--cyan)"  opacity="0.6" />
</svg>

<style>
  .arc {
    display: block;
    margin-top: 22px;
    overflow: visible;
    max-width: min(560px, 80vw);
  }
</style>
