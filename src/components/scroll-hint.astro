<div class="al-scroll-hint scroll-hint" aria-hidden="true">
  <span class="line"></span>
  <span class="text">SCROLL</span>
</div>

<style>
  .scroll-hint {
    flex-shrink: 0;
    margin-top: auto;
    align-self: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding-top: 28px;
    padding-bottom: max(12px, env(safe-area-inset-bottom));
  }
  .line {
    width: 1px;
    height: 36px;
    background: linear-gradient(180deg, transparent, var(--gold-dim));
  }
  .text {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.42em;
    color: var(--fg-dim);
  }
</style>
