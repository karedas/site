---
interface Props {
  num: string;
  label: string;
  accent?: 'amber' | 'sage' | 'cyan';
}

const { num, label, accent = 'amber' } = Astro.props;
const accentVar = `var(--${accent})`;
---
<div class="al-divider divider" role="presentation" aria-hidden="true">
  <span class="line"></span>
  <span class="caption">
    <span class="diamond">&#9670;</span>
    <span class="meta">Incoming</span>
    <span class="dot">&middot;</span>
    <span class="num" style={`color: ${accentVar}`}>{num}</span>
    <span class="slash">/</span>
    <span class="label">{label}</span>
    <span class="diamond">&#9670;</span>
  </span>
  <span class="line"></span>
</div>

<style>
  .divider {
    display: flex;
    align-items: center;
    gap: 24px;
    max-width: 1280px;
    margin: 0 auto;
    padding: 32px 80px;
  }
  .line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-dim), transparent);
  }
  .caption {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--fg-dim);
    white-space: nowrap;
  }
  .diamond {
    color: var(--gold-dim);
    font-size: 8px;
    letter-spacing: 0;
  }
  .meta { color: var(--fg-muted); }
  .dot {
    color: var(--gold);
    letter-spacing: 0;
    font-size: 12px;
  }
  .num { font-weight: 600; }
  .slash {
    color: var(--fg-dim);
    letter-spacing: 0;
  }
  .label { color: var(--fg); }

  @media (max-width: 1024px) {
    .divider { padding: 28px 48px; }
  }
  @media (max-width: 768px) {
    .divider { padding: 24px 28px; gap: 16px; }
    .caption { font-size: 9px; letter-spacing: 0.32em; }
    .meta { display: none; }
  }
  @media (max-width: 480px) {
    .divider { padding: 20px 20px; gap: 12px; }
    .caption { letter-spacing: 0.24em; gap: 8px; }
  }
</style>
