---
// Fixed left rail (desktop) + bottom bar (mobile) with scrollspy nav.
const navItems = [
  { num: '00', label: 'Home', href: '#top' },
  { num: '01', label: 'About', href: '#about' },
  { num: '02', label: 'Skills', href: '#skills' },
  { num: '03', label: 'Work', href: '#work' },
  { num: '04', label: 'Projects', href: '#projects' },
  { num: '05', label: 'Off-orbit', href: '#off-orbit' },
];
---
<nav class="rail" aria-label="Section navigation">
  <a class="logo" href="#top" aria-label="Back to top">AL</a>
  <div class="spacer" aria-hidden="true"></div>
  <div class="links">
    {navItems.map((nv) => (
      <a href={nv.href} title={nv.label} data-nav>{nv.num}</a>
    ))}
  </div>
  <div class="spacer" aria-hidden="true"></div>
  <div class="year" aria-hidden="true">MMXXVI</div>
</nav>

<nav class="bottom-bar" aria-label="Section navigation">
  <a class="logo" href="#top" aria-label="Back to top">AL</a>
  <div class="links">
    {navItems.map((nv) => (
      <a href={nv.href} title={nv.label} data-nav>{nv.num}</a>
    ))}
  </div>
</nav>

<style>
  .rail {
    position: fixed;
    top: 0;
    bottom: 0;
    left: 0;
    width: var(--rail-w);
    border-right: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 24px 0;
    gap: 26px;
    background: var(--bg);
    z-index: 50;
  }

  .rail .logo {
    font: 700 15px var(--font-display);
    letter-spacing: 0.05em;
    color: var(--accent);
  }

  .spacer {
    flex: 1;
    width: 1px;
    background: var(--line);
  }

  .rail .links {
    display: flex;
    flex-direction: column;
    gap: 18px;
    font: 500 10px var(--font-mono);
  }

  .links a {
    color: var(--fg-58);
    transition: color 0.2s;
  }

  .links a:hover,
  .links a.active {
    color: var(--accent);
  }

  .year {
    writing-mode: vertical-rl;
    font: 400 9px var(--font-mono);
    letter-spacing: 0.3em;
    color: var(--fg-52);
  }

  .bottom-bar {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 56px;
    align-items: center;
    justify-content: space-between;
    padding: 0 20px;
    border-top: 1px solid var(--line);
    background: rgba(25, 20, 18, 0.95);
    backdrop-filter: blur(8px);
    z-index: 50;
  }

  .bottom-bar .logo {
    font: 700 14px var(--font-display);
    color: var(--accent);
  }

  .bottom-bar .links {
    display: flex;
    gap: 18px;
    font: 500 11px var(--font-mono);
  }

  @media (max-width: 719px) {
    .rail {
      display: none;
    }

    .bottom-bar {
      display: flex;
    }
  }
</style>

<script>
  // Scrollspy: highlight the nav number of the section in view.
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-nav]'));
  const sections = Array.from(document.querySelectorAll<HTMLElement>('[data-sec]'));

  const setActive = (sec: string) => {
    for (const a of links) {
      a.classList.toggle('active', a.getAttribute('href') === `#${sec}`);
    }
  };

  const spy = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (e.isIntersecting) setActive(e.target.id);
      }
    },
    { rootMargin: '-40% 0px -55% 0px' },
  );
  for (const el of sections) spy.observe(el);
  setActive('top');
</script>
