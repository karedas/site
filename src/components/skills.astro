---
import SkillCloud from '@/components/react/skill-cloud';
import SectionHeader from '@/components/section-header.astro';

interface SkillItem {
  name: string;
  core?: boolean;
}
interface Group {
  title: string;
  items: SkillItem[];
}

const groups: Group[] = [
  {
    title: 'Technical Strategy',
    items: [
      {
        name: 'Frontend system design beyond components',
        core: true,
      },
      {
        name: 'Strategic modularization (business-shaped boundaries, low coupling)',
      },
      { name: 'Contract-driven development', core: true },
      { name: 'Observability' },
    ],
  },
  {
    title: 'Core Excellence',
    items: [
      { name: 'High-performance React, Vue, Angular & TS architectures', core: true },
      { name: 'Tech stack governance' },
      { name: 'Relational & NoSQL data' },
      { name: 'Resilient testing strategies' },
      { name: 'Cloud-agnostic deployments' },
    ],
  },
  {
    title: 'Developer Enablement',
    items: [
      { name: 'Large-scale repository architecture', core: true },
      { name: 'Standardization & tooling', core: true },
      { name: 'Source control & governance' },
      { name: 'Security & compliance' },
      { name: 'Deployment governance & DX' },
      { name: 'Docker / Kubernetes' },
      { name: 'Cloudflare Workers' },
      { name: 'APM & monitoring' },
      { name: 'Internal Developer Platform' },
    ],
  },
  {
    title: 'Engineering Leadership',
    items: [
      { name: 'Developer experience (DX)', core: true },
      { name: 'Mentoring & engineering culture', core: true },
      { name: 'RFCs & technical decision making' },
      { name: 'Figma / Adobe CC' },
    ],
  },
  {
    title: 'AI in practice',
    items: [{ name: 'AI-augmented workflow' }, { name: 'Pragmatic adoption · no hype' }],
  },
];
---
<section class="al-section section" id="skills">
  <SectionHeader num="02" title="Skills" subtitle="Where the time goes" accent="sage" />

  <div class="al-skills-layout layout">
    <div class="al-skills-cloud-wrap cloud-wrap">
      <SkillCloud client:load />
      <div class="cloud-chart">
        <div class="chart-line">
          <span class="chart-key">SECTOR</span>
          <span class="chart-dot">&middot;</span>
          <span class="chart-val">02 / SKILLS</span>
        </div>
        <div class="chart-line">
          <span class="chart-key">R</span>
          <span class="chart-val">235 AU</span>
          <span class="chart-dot">&middot;</span>
          <span class="chart-key">OBS</span>
          <span class="chart-val">MMXXVI</span>
        </div>
      </div>
    </div>

    <div class="al-skill-list list">
      {groups.map((g) => (
        <div class="group">
          <h3 class="al-skill-group-title group-title">{g.title}</h3>
          <div class="chips">
            {g.items.map((s) => (
              <span class:list={['chip', s.core && 'chip-core']}>
                {s.core && <span class="chip-marker" aria-hidden="true">&#9670;</span>}
                {s.name}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section {
    max-width: 1280px;
    margin: 0 auto;
    padding: 60px 80px;
    position: relative;
  }
  .layout {
    display: grid;
    grid-template-columns: minmax(360px, 0.9fr) 1fr;
    gap: 64px;
    align-items: center;
  }
  .cloud-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .cloud-chart {
    margin-top: 28px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: center;
  }
  .chart-line {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--fg-dim);
  }
  .chart-key { color: var(--fg-muted); font-weight: 500; }
  .chart-val { color: var(--fg); font-weight: 600; }
  .chart-dot { color: var(--gold); font-weight: 400; letter-spacing: 0; }

  .list {
    display: flex;
    flex-direction: column;
    gap: 36px;
  }
  .group {
    padding-left: 18px;
    border-left: 1px solid var(--border);
  }
  .group-title {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    margin: 0 0 18px;
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--fg-dim);
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--fg-muted);
    padding: 6px 12px;
    border: 1px solid var(--border-soft);
    border-radius: 2px;
    transition: color 200ms, border-color 200ms, background 200ms;
    cursor: default;
  }
  .chip:hover {
    color: var(--fg);
    border-color: var(--border);
    background: rgba(255, 255, 255, 0.02);
  }
  .chip-core {
    color: var(--amber);
    font-weight: 600;
    border-color: var(--gold-dim);
  }
  .chip-core:hover {
    color: var(--gold-hi);
    border-color: var(--amber);
    background: rgba(232, 161, 58, 0.06);
  }
  .chip-marker {
    color: var(--gold-dim);
    font-size: 9px;
    line-height: 1;
    transform: translateY(-1px);
  }
  .chip-core:hover .chip-marker {
    color: var(--amber);
  }
</style>
