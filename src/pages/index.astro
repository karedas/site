---
import Layout from '@/layouts/Layout.astro';
import CornerMarks from '@/components/CornerMarks.astro';
import Hero from '@/components/Hero.astro';
import TransmissionDivider from '@/components/TransmissionDivider.astro';
import About from '@/components/About.astro';
import Skills from '@/components/Skills.astro';
import Work from '@/components/Work.astro';
import Footer from '@/components/Footer.astro';
---
<Layout>
  <CornerMarks />
  <Hero />
  <TransmissionDivider num="01" label="About" accent="amber" />
  <About />
  <TransmissionDivider num="02" label="Skills" accent="sage" />
  <Skills />
  <TransmissionDivider num="03" label="Selected Work" accent="cyan" />
  <Work />
  <Footer />
</Layout>
