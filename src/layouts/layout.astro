---
import '@/styles/tokens.css';
import '@/styles/global.css';
import '@/styles/responsive.css';
import Analytics from '@/components/analytics.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Andrea Lisi · Senior Software Engineer · Observed from Earth',
  description = 'Twenty years of art merging into code. Senior Software Engineer in Vienna, working on platform architecture and governance, and the small details that make systems calm.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL('/og-image.jpg', Astro.site).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0a0c17" />
    <meta name="color-scheme" content="dark" />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color="#e8a13a" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Andrea Lisi" />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Andrea Lisi" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Andrea Lisi, Senior Software Engineer in Vienna" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Andrea Lisi, Senior Software Engineer in Vienna" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,300;1,400;1,500&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <Analytics />
  </head>
  <body id="al-site">
    <slot />
  </body>
</html>
